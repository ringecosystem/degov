    node ./scripts/indexer-accuracy-diagnose.test.mjs
    node ./scripts/indexer-reconcile-diagnose.test.mjs
    cargo test --locked
    node ./scripts/check-rust-conventions.test.mjs
    node ./scripts/compatibility-preflight.test.mjs

