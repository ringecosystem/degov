# Database Configuration
DEGOV_DB_PASSWORD=change_me_to_a_secure_password
DEGOV_DB_PORT=7453

# Sync authentication token (must match between web and indexer)
# Generate with: openssl rand -hex 32
DEGOV_SYNC_AUTH_TOKEN=change_me_generate_with_openssl

# Web application JWT secret
# Generate with: openssl rand -hex 32
DEGOV_WEB_JWT_SECRET=change_me_generate_with_openssl

# IGRA RPC endpoint
CHAIN_RPC_1=add_your_rpc_endpoint_here

# Service ports
DEGOV_WEB_PORT=3002
DEGOV_INDEXER_PORT=4350

# Optional: AI-powered proposal analysis
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
