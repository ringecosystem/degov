# {{ ansible_managed }}
# Auto-generated .env — define variables in group_vars, host_vars, or --extra-vars

{% if degov_db_password is not defined %}
{{ "ERROR: degov_db_password is required. Set it in group_vars/all/vars.yml or pass via --extra-vars" | mandatory }}
{% endif %}
{% if degov_sync_auth_token is not defined %}
{{ "ERROR: degov_sync_auth_token is required. Generate with: openssl rand -hex 32" | mandatory }}
{% endif %}
{% if degov_web_jwt_secret is not defined %}
{{ "ERROR: degov_web_jwt_secret is required. Generate with: openssl rand -hex 32" | mandatory }}
{% endif %}

# Database Configuration
DEGOV_DB_PASSWORD={{ degov_db_password }}
DEGOV_DB_PORT=7453

# Sync authentication token (must match between web and indexer)
DEGOV_SYNC_AUTH_TOKEN={{ degov_sync_auth_token }}

# Web application JWT secret
DEGOV_WEB_JWT_SECRET={{ degov_web_jwt_secret }}

# Chain RPC endpoints
CHAIN_RPC_1={{ chain_rpc_1 | default('https://rpc.igralabs.com:8545') }}
CHAIN_RPC_38833={{ chain_rpc_38833 | default(chain_rpc_1 | default('https://rpc.igralabs.com:8545')) }}

# Service ports (must match nginx upstream: host.docker.internal:3002)
DEGOV_WEB_PORT=3002
DEGOV_INDEXER_PORT=4350

# Optional: AI-powered proposal analysis
{% if openrouter_api_key is defined and openrouter_api_key %}
OPENROUTER_API_KEY={{ openrouter_api_key }}
OPENROUTER_DEFAULT_MODEL={{ openrouter_default_model | default('anthropic/claude-3.5-sonnet') }}
{% endif %}
